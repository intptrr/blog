---
import { SITE_AUTHOR, SITE_EMAIL } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-rule font-serif text-[0.85rem] text-fg-muted">
	<div class="mx-auto max-w-[var(--container-measure)] px-5 pt-6 pb-8">
		<div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<p class="m-0">
					© {year} {SITE_AUTHOR} ·
					<a
						href={`mailto:${SITE_EMAIL}`}
						class="text-fg-muted underline underline-offset-[3px] hover:text-fg"
					>{SITE_EMAIL}</a> ·
					<a
						href="/rss.xml"
						class="text-fg-muted underline underline-offset-[3px] hover:text-fg"
					>RSS</a>
				</p>
			</div>
			<div
				class="flex gap-[0.875rem] font-mono text-[0.75rem] text-fg-muted opacity-85"
				aria-hidden="true"
			>
				<span>[eip: 0x080483f4]</span>
				<span>[esp: 0xbffff5c0]</span>
				<span class="animate-pulse text-accent">● heap_leaked</span>
			</div>
		</div>
	</div>
</footer>
