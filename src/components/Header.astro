---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 border-b border-rule bg-bg/85 backdrop-blur-md">
	<div
		class="mx-auto flex max-w-[var(--container-measure)] items-center gap-4 px-5 py-3 sm:gap-6"
	>
		<a
			class="font-serif text-[1.35rem] font-bold tracking-[-0.01em] text-fg no-underline"
			style="font-optical-sizing: auto; font-variation-settings: 'opsz' 144, 'SOFT' 100;"
			href="/"
		>
			{SITE_TITLE}
		</a>

		<nav
			id="primary-nav"
			class="ml-auto hidden sm:block"
			aria-label="Primary"
			data-nav
		>
			<ul class="m-0 flex list-none flex-wrap items-center gap-6 p-0">
				{NAV_LINKS.map((link) => {
					const active = isActive(link.href);
					return (
						<li>
							<a
								href={link.href}
								aria-current={active ? 'page' : undefined}
								class:list={[
									'group relative inline-block py-1 font-sans text-[0.9rem] font-medium no-underline transition-colors duration-200 ease-in-out',
									active ? 'text-fg' : 'text-fg-muted hover:text-fg',
								]}
							>
								<span>{link.label}</span>
								<span
									class:list={[
										'absolute -bottom-0.5 left-0 h-[1.5px] bg-accent transition-all duration-300 ease-out',
										active
											? 'w-full'
											: 'w-0 group-hover:w-full',
									]}
									aria-hidden="true"
								></span>
							</a>
						</li>
					);
				})}
			</ul>
		</nav>

		<div class="ml-auto flex items-center gap-2 sm:ml-0">
			<ThemeToggle />
			<button
				type="button"
				id="nav-toggle"
				class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-rule text-fg-muted transition-colors hover:text-fg sm:hidden"
				aria-controls="primary-nav"
				aria-expanded="false"
				aria-label="Toggle navigation menu"
			>
				<svg
					class="h-5 w-5"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M4 7h16M4 12h16M4 17h16"
						data-icon="open"
					></path>
					<path
						class="hidden"
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M6 6l12 12M6 18L18 6"
						data-icon="close"
					></path>
				</svg>
			</button>
		</div>
	</div>

	<nav
		id="primary-nav-mobile"
		class="hidden border-t border-rule sm:hidden"
		aria-label="Primary mobile"
		data-nav-mobile
	>
		<ul class="m-0 flex list-none flex-col gap-1 px-5 py-3 p-0">
			{NAV_LINKS.map((link) => {
				const active = isActive(link.href);
				return (
					<li>
						<a
							href={link.href}
							aria-current={active ? 'page' : undefined}
							class:list={[
								'block rounded-md px-3 py-2 font-sans text-[0.95rem] font-medium no-underline transition-colors duration-200 ease-in-out',
								active
									? 'text-fg bg-fg/5'
									: 'text-fg-muted hover:text-fg hover:bg-fg/5',
							]}
						>
							{link.label}
						</a>
					</li>
				);
			})}
		</ul>
	</nav>
</header>

<script>
	const toggle = document.getElementById('nav-toggle');
	const mobileNav = document.getElementById('primary-nav-mobile');
	const iconOpen = toggle?.querySelector('[data-icon="open"]');
	const iconClose = toggle?.querySelector('[data-icon="close"]');

	function setOpen(open: boolean) {
		if (!toggle || !mobileNav) return;
		toggle.setAttribute('aria-expanded', String(open));
		mobileNav.classList.toggle('hidden', !open);
		iconOpen?.classList.toggle('hidden', open);
		iconClose?.classList.toggle('hidden', !open);
	}

	toggle?.addEventListener('click', () => {
		const open = toggle.getAttribute('aria-expanded') === 'true';
		setOpen(!open);
	});

	// Close on resize to desktop
	window.addEventListener('resize', () => {
		if (window.innerWidth >= 640) setOpen(false);
	});

	// Close when a link is clicked
	mobileNav?.querySelectorAll('a').forEach((a) =>
		a.addEventListener('click', () => setOpen(false))
	);
</script>
</content>
