---
import Layout from "../layouts/Layout.astro";
import { SITE_AUTHOR, SITE_EMAIL } from "../consts";

const links = [
	{ label: "Email", href: `mailto:${SITE_EMAIL}`, value: SITE_EMAIL },
	{ label: "GitHub", href: "https://github.com/intptrr", value: "@intptrr" },
	{ label: "Twitter", href: "https://twitter.com/intptrr", value: "@intptrr" },
	{
		label: "Instagram",
		href: "https://instagram.com/intptrr64",
		value: "@intptrr64",
	},
	{ label: "Telegram", href: "https://t.me/intptrr64", value: "@intptrr64" },
	{ label: "RSS", href: "/rss.xml", value: "subscribe" },
];

const now = [
	{ label: "Building", value: "automation for personal assistance." },
	{ label: "Reading", value: "finance, computer science, and novels." },
	{ label: "Listening", value: "J-Pop and electronic music." },
	{ label: "Watching", value: "anime." },
	{ label: "Traveling", value: "none. Europe trip canceled." },
];

const timeline = [
	{
		year: "2025",
		text: "Container registry, Kubernetes, Go, open source, and distributed systems.",
	},
	{ year: "2022", text: "IaC platform work with C#, PowerShell, and Azure." },
	{
		year: "2019",
		text: "Full-stack with Vue.js, TypeScript, and Spring Boot.",
	},
	{ year: "2015", text: "College, Python, C++, and Linux." },
	{ year: "2012", text: "Started with RobotC and FTC robotics." },
];
---

<Layout title="About" description={`A short bio of ${SITE_AUTHOR}.`}>
	<h1>About</h1>
	<p class="-mt-2 mb-8 max-w-[38rem] text-fg-muted">
		Hi, I'm <strong class="text-fg">Jinwei Wang</strong>, also known as
		<strong class="text-fg">{SITE_AUTHOR}</strong>. I'm a software engineer on
		the Container Registry team at Azure Core. When I'm not writing code, you'll
		find me watching anime, chasing powder on the slopes, or planning my next
		adventure. Always happy to connect — don't hesitate to reach out.
	</p>

	<div class="prose">
		<pre><code class="language-rust">{`struct Developer {
    name: "${SITE_AUTHOR}",
	stack: ["C#", "Go", "Kubernetes", "TypeScript", "Linux"],
	status: "studying",
}`}</code></pre>

		<h2
			class="!mb-3 font-mono !text-[0.85rem] !font-semibold uppercase !tracking-[0.12em] text-fg-muted"
		>
			Currently
		</h2>
		<dl
			class="!mt-3 !mb-10 grid grid-cols-[7rem_1fr] gap-x-5 gap-y-2 font-sans text-[0.95rem]"
		>
			{
				now.map((row) => (
					<>
						<dt class="text-fg-muted">{row.label}</dt>
						<dd class="m-0 text-fg">{row.value}</dd>
					</>
				))
			}
		</dl>

		<h2
			class="!mb-3 font-mono !text-[0.85rem] !font-semibold uppercase !tracking-[0.12em] text-fg-muted"
		>
			Elsewhere
		</h2>
		<ul
			class="!mt-3 !mb-10 !list-none !pl-0 grid grid-cols-1 gap-x-8 gap-y-2 sm:grid-cols-2"
		>
			{
				links.map((link) => (
					<li class="!mb-0 !pl-0 flex flex-wrap items-baseline gap-x-3 before:!hidden">
						<span class="w-[6rem] shrink-0 font-sans text-[0.9rem] text-fg-muted">
							{link.label}
						</span>
						<a href={link.href} class="font-sans text-[0.95rem]">
							{link.value}
						</a>
					</li>
				))
			}
		</ul>

		<h2
			class="!mb-3 font-mono !text-[0.85rem] !font-semibold uppercase !tracking-[0.12em] text-fg-muted"
		>
			A short history
		</h2>
		<ol class="!mt-3 !mb-10 !list-none !pl-0 border-l border-rule">
			{
				timeline.map((item) => (
					<li class="!mb-3 !pl-5 relative before:!hidden">
						<span
							class="absolute -left-[5px] top-[0.55rem] block h-2 w-2 rounded-full bg-accent"
							aria-hidden="true"
						/>
						<span class="block font-mono text-[0.78rem] font-medium uppercase tracking-[0.12em] text-fg-muted">
							{item.year}
						</span>
						<span class="block font-sans text-[0.95rem] text-fg">
							{item.text}
						</span>
					</li>
				))
			}
		</ol>

		<h2
			class="!mb-3 font-mono !text-[0.85rem] !font-semibold uppercase !tracking-[0.12em] text-fg-muted"
		>
			Colophon
		</h2>
		<p class="!mt-3 font-sans text-[0.95rem] text-fg-muted">
			Built with <a href="https://astro.build">Astro</a> and
			<a href="https://tailwindcss.com">Tailwind&nbsp;CSS</a>. Set in
			<a href="https://fonts.google.com/specimen/Fraunces">Fraunces</a> (serif),
			<a href="https://rsms.me/inter/">Inter</a> (sans), and the system monospace.
			Code blocks rendered with
			<a href="https://rehype-pretty.pages.dev/">rehype-pretty-code</a> +
			<a href="https://shiki.style/">Shiki</a>. Source on
			<a href="https://github.com/intptrr/blog">GitHub</a>.
		</p>
	</div>
</Layout>
