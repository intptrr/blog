---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';

// Drop photos into `src/assets/gallery/` — they are picked up automatically,
// optimized at build time, and sorted by filename (newest-named first).
const modules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/gallery/*.{jpeg,jpg,png,webp,avif,gif}',
	{ eager: true },
);

const photos = Object.entries(modules)
	.map(([path, mod]) => {
		const file = path.split('/').pop() ?? '';
		const name = file.replace(/\.[^.]+$/, '');
		// Turn a filename like "2026-05-kyoto-station" into "Kyoto station".
		const label = name
			.replace(/^\d{4}[-_]?\d{0,2}[-_]?\d{0,2}[-_]?/, '')
			.replace(/[-_]+/g, ' ')
			.trim();
		return { src: mod.default, alt: label || name };
	})
	.sort((a, b) => b.src.src.localeCompare(a.src.src));
---

<Layout title="Gallery" description="Photographs." fullWidth>
	<h1 class="mb-8 text-center">Gallery</h1>

	{photos.length === 0 ? (
		<div class="mx-auto w-full max-w-[var(--container-measure)] rounded-card border border-dashed border-rule bg-bg-soft px-6 py-12 text-center">
			<p class="m-0 font-sans text-fg-muted">
				No photos yet. Drop image files into
				<code>src/assets/gallery/</code> and they'll show up here.
			</p>
		</div>
	) : (
		<div class="gallery-grid">
			{photos.map((photo, i) => (
				<button
					type="button"
					class="gallery-item group"
					data-full={photo.src.src}
					data-alt={photo.alt}
					aria-label={`View photo: ${photo.alt}`}
				>
					<Image
						src={photo.src}
						alt={photo.alt}
						widths={[320, 640, 960]}
						sizes="(min-width: 1280px) 20vw, (min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
						loading={i < 6 ? 'eager' : 'lazy'}
						class="gallery-img"
					/>
				</button>
			))}
		</div>
	)}

	{/* Lightbox */}
	<div
		id="lightbox"
		class="lightbox"
		role="dialog"
		aria-modal="true"
		aria-label="Photo viewer"
		hidden
	>
		<button type="button" class="lightbox-btn lightbox-close" aria-label="Close">
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path d="M6 6l12 12M18 6L6 18" />
			</svg>
		</button>
		<button type="button" class="lightbox-btn lightbox-nav lightbox-prev" aria-label="Previous photo">
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path d="M15 5l-7 7 7 7" />
			</svg>
		</button>
		<div class="lightbox-spinner" aria-hidden="true"></div>
		<img id="lightbox-img" class="lightbox-img" src="" alt="" />
		<button type="button" class="lightbox-btn lightbox-nav lightbox-next" aria-label="Next photo">
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path d="M9 5l7 7-7 7" />
			</svg>
		</button>
	</div>
</Layout>

<style>
	/* Masonry via CSS columns — full-bleed, responsive column count. */
	.gallery-grid {
		column-gap: 0.75rem;
		columns: 2;
	}
	@media (min-width: 640px) {
		.gallery-grid {
			columns: 3;
		}
	}
	@media (min-width: 1024px) {
		.gallery-grid {
			columns: 4;
		}
	}
	@media (min-width: 1536px) {
		.gallery-grid {
			columns: 5;
		}
	}

	.gallery-item {
		display: block;
		width: 100%;
		margin: 0 0 0.75rem;
		padding: 0;
		border: 0;
		background: none;
		cursor: zoom-in;
		break-inside: avoid;
		border-radius: var(--radius-card);
		overflow: hidden;
		line-height: 0;
	}
	.gallery-img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: var(--radius-card);
		background: var(--color-bg-soft);
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), filter 0.35s ease;
	}
	.gallery-item:hover .gallery-img,
	.gallery-item:focus-visible .gallery-img {
		transform: scale(1.04);
		filter: brightness(1.03);
	}

	/* Lightbox overlay */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		background: color-mix(in srgb, #000 86%, transparent);
		backdrop-filter: blur(6px);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.lightbox[data-open] {
		opacity: 1;
	}
	.lightbox-img {
		max-width: 100%;
		max-height: 100%;
		border-radius: var(--radius-card);
		box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.7);
		opacity: 0;
		transform: scale(0.97);
		transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.lightbox[data-open] .lightbox-img {
		transform: scale(1);
	}
	.lightbox[data-open]:not([data-loading]) .lightbox-img {
		opacity: 1;
	}
	.lightbox-spinner {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 2.5rem;
		height: 2.5rem;
		margin: -1.25rem 0 0 -1.25rem;
		border: 3px solid rgba(255, 255, 255, 0.25);
		border-top-color: #fff;
		border-radius: 50%;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease;
		animation: lightbox-spin 0.7s linear infinite;
	}
	.lightbox[data-loading] .lightbox-spinner {
		opacity: 1;
	}
	@keyframes lightbox-spin {
		to {
			transform: rotate(360deg);
		}
	}
	.lightbox-btn {
		position: absolute;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		color: #fff;
		background: rgba(20, 20, 20, 0.45);
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 999px;
		cursor: pointer;
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
		transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
	}
	.lightbox-btn svg {
		width: 60%;
		height: 60%;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	.lightbox-btn:hover {
		background: rgba(40, 40, 40, 0.65);
		border-color: rgba(255, 255, 255, 0.3);
	}
	.lightbox-btn:active {
		transform: scale(0.92);
	}
	.lightbox-btn:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 2px;
	}
	.lightbox-btn[hidden] {
		display: none;
	}

	.lightbox-close {
		top: clamp(0.75rem, 2vw, 1.25rem);
		right: clamp(0.75rem, 2vw, 1.25rem);
		width: 2.5rem;
		height: 2.5rem;
	}

	.lightbox-nav {
		top: 50%;
		transform: translateY(-50%);
		width: 2.5rem;
		height: 2.5rem;
	}
	.lightbox-nav:active {
		transform: translateY(-50%) scale(0.92);
	}
	.lightbox-prev {
		left: clamp(0.75rem, 2vw, 1.5rem);
	}
	.lightbox-next {
		right: clamp(0.75rem, 2vw, 1.5rem);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-img,
		.lightbox,
		.lightbox-img {
			transition: none;
		}
		.lightbox-spinner {
			animation-duration: 1.4s;
		}
	}
</style>

<script>
	const lightbox = document.getElementById('lightbox') as HTMLElement | null;
	const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
	const closeBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-close');
	const prevBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-prev');
	const nextBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-next');
	const items = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item'));
	let lastFocused: HTMLElement | null = null;
	let currentIndex = -1;

	function showPhoto(index: number) {
		if (!lightbox || !lightboxImg || index < 0 || index >= items.length) return;
		const item = items[index];
		const src = item.dataset.full;
		if (!src) return;
		currentIndex = index;
		lightbox.setAttribute('data-loading', '');
		lightboxImg.src = src;
		lightboxImg.alt = item.dataset.alt ?? '';
		// Cached images are already complete — skip the spinner flash.
		if (lightboxImg.complete) lightbox.removeAttribute('data-loading');
		const multiple = items.length > 1;
		if (prevBtn) prevBtn.hidden = !multiple;
		if (nextBtn) nextBtn.hidden = !multiple;
	}

	function openLightbox(index: number) {
		if (!lightbox || !lightboxImg) return;
		lastFocused = document.activeElement as HTMLElement;
		showPhoto(index);
		lightbox.hidden = false;
		requestAnimationFrame(() => lightbox.setAttribute('data-open', ''));
		document.body.style.overflow = 'hidden';
		closeBtn?.focus();
	}

	function closeLightbox() {
		if (!lightbox || !lightboxImg) return;
		lightbox.removeAttribute('data-open');
		document.body.style.overflow = '';
		const done = () => {
			lightbox.hidden = true;
			lightboxImg.src = '';
			lightbox.removeEventListener('transitionend', done);
		};
		lightbox.addEventListener('transitionend', done);
		lastFocused?.focus();
	}

	function navigate(delta: number) {
		if (currentIndex < 0 || items.length === 0) return;
		showPhoto((currentIndex + delta + items.length) % items.length);
	}

	items.forEach((item, i) => {
		item.addEventListener('click', () => openLightbox(i));
	});

	const clearLoading = () => lightbox?.removeAttribute('data-loading');
	lightboxImg?.addEventListener('load', clearLoading);
	lightboxImg?.addEventListener('error', clearLoading);

	closeBtn?.addEventListener('click', closeLightbox);
	prevBtn?.addEventListener('click', () => navigate(-1));
	nextBtn?.addEventListener('click', () => navigate(1));
	lightbox?.addEventListener('click', (e) => {
		if (e.target === lightbox) closeLightbox();
	});
	document.addEventListener('keydown', (e) => {
		if (!lightbox || lightbox.hidden) return;
		switch (e.key) {
			case 'Escape':
				closeLightbox();
				break;
			case 'ArrowLeft':
				navigate(-1);
				break;
			case 'ArrowRight':
				navigate(1);
				break;
		}
	});
</script>
