---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';

// Drop photos into `src/assets/gallery/` — they are picked up automatically,
// optimized at build time, and sorted by filename (newest-named first).
const modules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/gallery/*.{jpeg,jpg,png,webp,avif,gif}',
	{ eager: true },
);

const photos = Object.entries(modules)
	.map(([path, mod]) => {
		const file = path.split('/').pop() ?? '';
		const name = file.replace(/\.[^.]+$/, '');
		// Turn a filename like "2026-05-kyoto-station" into "Kyoto station".
		const label = name
			.replace(/^\d{4}[-_]?\d{0,2}[-_]?\d{0,2}[-_]?/, '')
			.replace(/[-_]+/g, ' ')
			.trim();
		return { src: mod.default, alt: label || name };
	})
	.sort((a, b) => b.src.src.localeCompare(a.src.src));
---

<Layout title="Gallery" description="Photographs." fullWidth>
	<h1 class="mb-8 text-center">Gallery</h1>

	{photos.length === 0 ? (
		<div class="mx-auto w-full max-w-[var(--container-measure)] rounded-card border border-dashed border-rule bg-bg-soft px-6 py-12 text-center">
			<p class="m-0 font-sans text-fg-muted">
				No photos yet. Drop image files into
				<code>src/assets/gallery/</code> and they'll show up here.
			</p>
		</div>
	) : (
		<div id="gallery" class="gallery-grid">
			{photos.map((photo, i) => (
				<a
					class="gallery-item group"
					href={photo.src.src}
					data-pswp-width={photo.src.width}
					data-pswp-height={photo.src.height}
					target="_blank"
					rel="noreferrer"
					aria-label={`View photo: ${photo.alt}`}
				>
					<Image
						src={photo.src}
						alt={photo.alt}
						widths={[320, 640, 960]}
						sizes="(min-width: 1280px) 20vw, (min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
						loading={i < 6 ? 'eager' : 'lazy'}
						class="gallery-img"
					/>
				</a>
			))}
		</div>
	)}
</Layout>

<style>
	/* Masonry via CSS columns — full-bleed, responsive column count. */
	.gallery-grid {
		column-gap: 0.75rem;
		columns: 2;
	}
	@media (min-width: 640px) {
		.gallery-grid {
			columns: 3;
		}
	}
	@media (min-width: 1024px) {
		.gallery-grid {
			columns: 4;
		}
	}
	@media (min-width: 1536px) {
		.gallery-grid {
			columns: 5;
		}
	}

	.gallery-item {
		display: block;
		width: 100%;
		margin: 0 0 0.75rem;
		cursor: zoom-in;
		break-inside: avoid;
		border-radius: var(--radius-card);
		overflow: hidden;
		line-height: 0;
	}
	.gallery-img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: var(--radius-card);
		background: var(--color-bg-soft);
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), filter 0.35s ease;
	}
	.gallery-item:hover .gallery-img,
	.gallery-item:focus-visible .gallery-img {
		transform: scale(1.04);
		filter: brightness(1.03);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-img {
			transition: none;
		}
	}
</style>

<script>
	import PhotoSwipeLightbox from 'photoswipe/lightbox';
	import 'photoswipe/style.css';

	const lightbox = new PhotoSwipeLightbox({
		gallery: '#gallery',
		children: 'a.gallery-item',
		pswpModule: () => import('photoswipe'),
		bgOpacity: 0.92,
		loop: true,
	});
	lightbox.init();
</script>
