---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';

// Drop photos into `src/assets/gallery/` — they are picked up automatically,
// optimized at build time, and sorted by filename (newest-named first).
const modules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/gallery/*.{jpeg,jpg,png,webp,avif,gif}',
	{ eager: true },
);

const photos = Object.entries(modules)
	.map(([path, mod]) => {
		const file = path.split('/').pop() ?? '';
		const name = file.replace(/\.[^.]+$/, '');
		// Turn a filename like "2026-05-kyoto-station" into "Kyoto station".
		const label = name
			.replace(/^\d{4}[-_]?\d{0,2}[-_]?\d{0,2}[-_]?/, '')
			.replace(/[-_]+/g, ' ')
			.trim();
		return { src: mod.default, alt: label || name };
	})
	.sort((a, b) => b.src.src.localeCompare(a.src.src));
---

<Layout title="Gallery" description="Photographs." fullWidth>
	<h1 class="mb-8 text-center">Gallery</h1>

	{photos.length === 0 ? (
		<div class="mx-auto w-full max-w-[var(--container-measure)] rounded-card border border-dashed border-rule bg-bg-soft px-6 py-12 text-center">
			<p class="m-0 font-sans text-fg-muted">
				No photos yet. Drop image files into
				<code>src/assets/gallery/</code> and they'll show up here.
			</p>
		</div>
	) : (
		<div class="gallery-grid">
			{photos.map((photo, i) => (
				<button
					type="button"
					class="gallery-item group"
					data-full={photo.src.src}
					data-alt={photo.alt}
					aria-label={`View photo: ${photo.alt}`}
				>
					<Image
						src={photo.src}
						alt={photo.alt}
						widths={[320, 640, 960]}
						sizes="(min-width: 1280px) 20vw, (min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
						loading={i < 6 ? 'eager' : 'lazy'}
						class="gallery-img"
					/>
				</button>
			))}
		</div>
	)}

	{/* Lightbox */}
	<div
		id="lightbox"
		class="lightbox"
		role="dialog"
		aria-modal="true"
		aria-label="Photo viewer"
		hidden
	>
		<button type="button" class="lightbox-close" aria-label="Close">&times;</button>
		<img id="lightbox-img" class="lightbox-img" src="" alt="" />
	</div>
</Layout>

<style>
	/* Masonry via CSS columns — full-bleed, responsive column count. */
	.gallery-grid {
		column-gap: 0.75rem;
		columns: 2;
	}
	@media (min-width: 640px) {
		.gallery-grid {
			columns: 3;
		}
	}
	@media (min-width: 1024px) {
		.gallery-grid {
			columns: 4;
		}
	}
	@media (min-width: 1536px) {
		.gallery-grid {
			columns: 5;
		}
	}

	.gallery-item {
		display: block;
		width: 100%;
		margin: 0 0 0.75rem;
		padding: 0;
		border: 0;
		background: none;
		cursor: zoom-in;
		break-inside: avoid;
		border-radius: var(--radius-card);
		overflow: hidden;
		line-height: 0;
	}
	.gallery-img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: var(--radius-card);
		background: var(--color-bg-soft);
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), filter 0.35s ease;
	}
	.gallery-item:hover .gallery-img,
	.gallery-item:focus-visible .gallery-img {
		transform: scale(1.04);
		filter: brightness(1.03);
	}

	/* Lightbox overlay */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		background: color-mix(in srgb, #000 86%, transparent);
		backdrop-filter: blur(6px);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.lightbox[data-open] {
		opacity: 1;
	}
	.lightbox-img {
		max-width: 100%;
		max-height: 100%;
		border-radius: var(--radius-card);
		box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.7);
		transform: scale(0.97);
		transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.lightbox[data-open] .lightbox-img {
		transform: scale(1);
	}
	.lightbox-close {
		position: absolute;
		top: 1rem;
		right: 1.25rem;
		width: 2.5rem;
		height: 2.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 1.75rem;
		line-height: 1;
		color: #fff;
		background: rgba(255, 255, 255, 0.1);
		border: 0;
		border-radius: 999px;
		cursor: pointer;
		transition: background 0.2s ease;
	}
	.lightbox-close:hover {
		background: rgba(255, 255, 255, 0.2);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-img,
		.lightbox,
		.lightbox-img {
			transition: none;
		}
	}
</style>

<script>
	const lightbox = document.getElementById('lightbox') as HTMLElement | null;
	const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
	const closeBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-close');
	let lastFocused: HTMLElement | null = null;

	function openLightbox(src: string, alt: string) {
		if (!lightbox || !lightboxImg) return;
		lastFocused = document.activeElement as HTMLElement;
		lightboxImg.src = src;
		lightboxImg.alt = alt;
		lightbox.hidden = false;
		requestAnimationFrame(() => lightbox.setAttribute('data-open', ''));
		document.body.style.overflow = 'hidden';
		closeBtn?.focus();
	}

	function closeLightbox() {
		if (!lightbox || !lightboxImg) return;
		lightbox.removeAttribute('data-open');
		document.body.style.overflow = '';
		const done = () => {
			lightbox.hidden = true;
			lightboxImg.src = '';
			lightbox.removeEventListener('transitionend', done);
		};
		lightbox.addEventListener('transitionend', done);
		lastFocused?.focus();
	}

	document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
		item.addEventListener('click', () => {
			const src = item.dataset.full;
			const alt = item.dataset.alt ?? '';
			if (src) openLightbox(src, alt);
		});
	});

	closeBtn?.addEventListener('click', closeLightbox);
	lightbox?.addEventListener('click', (e) => {
		if (e.target === lightbox) closeLightbox();
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && lightbox && !lightbox.hidden) closeLightbox();
	});
</script>
