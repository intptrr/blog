---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PostList from '../../components/PostList.astro';

export const getStaticPaths = (async () => {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	const tags = new Set<string>();
	for (const post of posts) {
		for (const t of post.data.tags) tags.add(t);
	}
	return [...tags].map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((p) => p.data.tags.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---

<Layout title={`#${tag}`} description={`Posts tagged ${tag}.`}>
	<p class="mb-2 text-[0.9rem]">
		<a href="/blog" class="text-fg-muted no-underline hover:text-fg">← Clear filter</a>
	</p>

	<div class="mb-2 inline-flex items-center gap-2 rounded-full border border-accent bg-bg-soft px-3 py-1 text-[0.9rem] font-medium text-accent">
		#{tag}
	</div>

	<p class="-mt-1 text-fg-muted">
		{posts.length} post{posts.length === 1 ? '' : 's'} tagged <code>{tag}</code>.
	</p>

	<PostList posts={posts} />
</Layout>
